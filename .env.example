# Supabase (публични ключове)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# За изтриване на имоти от админ – service role ключ (минава през RLS). В Supabase: Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Админ панел – парола за влизане (задължително)
ADMIN_PASSWORD=your-secure-admin-password

# Секрет за подпис на сесията (по желание; ако липсва, използва се ADMIN_PASSWORD)
# Генерирай с: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# =============================================================================
# Google – аналитика и Search Console (по желание; всички са публични NEXT_PUBLIC_*)
# =============================================================================
# GA4: Google Analytics → Admin → Data streams → избери поток → Measurement ID (G-XXXXXXXXXX)
# След съгласие за „Аналитични бисквитки“ се зарежда gtag.js и се изпращат данни към GA4.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager: само ако ползвате GTM (контейнер GTM-XXXXXXX). Зарежда се при същото съгласие.
# Не слагайте едновременно GA4 през gtag И същия GA4 само през GTM – дублиране на данни.
NEXT_PUBLIC_GTM_CONTAINER_ID=

# Search Console: Настройки → потвърждаване на собственост → HTML таг → копирай стойността на content=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
